{
  "name": "@ilms/monorepo",
  "private": true,
  "workspaces": ["apps/web", "apps/desktop", "apps/server", "apps/mcp", "packages/*"],
  "type": "module",
  "scripts": {
    "dev": "bun run --filter @ilms/web dev",
    "dev:web": "bun run --filter @ilms/web dev",
    "dev:server": "bun run --filter @ilms/server dev",
    "dev:desktop": "bun run --filter @ilms/desktop dev",
    "build": "turbo run build --filter=@ilms/web",
    "build:desktop": "turbo run build --filter=@ilms/desktop",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "bun run typecheck && bun run test && bun run build"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "bun": "^1.3.9"
  },
  "packageManager": "bun@1.3.9"
}
